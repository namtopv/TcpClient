<Window x:Class="TcpClient.Views.UARTView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TcpClient.Views"
        mc:Ignorable="d"
        Title="UARTView" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header=" Cấu hình kết nối " Grid.Row="0" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Name" 
                   VerticalAlignment="Center" 
                   Margin="0,0,5,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Comports}"
                          SelectedItem="{Binding SelectedComPort, Mode=TwoWay}"/>

                <TextBlock Grid.Column="2" Text="Baud" 
                           VerticalAlignment="Center" 
                           Margin="10,0,5,0"/>
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding Baud}"
                          SelectedItem="{Binding SelectedBaud, Mode=TwoWay}"/>

                <TextBlock Grid.Column="4" Text="Size" 
                           VerticalAlignment="Center" 
                           Margin="10,0,5,0"/>
                <ComboBox Grid.Column="5"
                          ItemsSource="{Binding Size}"
                          SelectedItem="{Binding SelectedSize, Mode=TwoWay}"/>
                <Button x:Name="btnConnect" 
                        Grid.Column="6" 
                        Background="LightCoral" 
                        Content="Kết nối" 
                        Margin="10,0,0,0" 
                        Padding="10,3" 
                        Foreground="Black" 
                        FontWeight="Bold"
                        Command="{Binding ConnectCommand}"/>
            </Grid>
        </GroupBox>

        <GroupBox Header=" Gửi dữ liệu đi " Grid.Row="1" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtMessage" Text="{Binding TxtMessage}" VerticalAlignment="Center" Padding="5"/>
                <Button x:Name="btnSend" Grid.Column="1" Content="SEND" Command="{Binding SENDCommand}" Background="#2196F3" Foreground="White" FontWeight="Bold" IsDefault="True" Width=" 70"/>
                <Button x:Name="btnReqt" Grid.Column="2" Content="REQT" Command="{Binding REQTCommand}" Background="#2196F3" Foreground="White" FontWeight="Bold" IsDefault="True" Width=" 70"/>
            </Grid>
        </GroupBox>

        <GroupBox Header=" Nhật ký / Dữ liệu nhận được " Grid.Row="2" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding TbMessage}"/>
                <Button x:Name="btnHex" Grid.Column="1" Content=" HEX/ASCII " Margin="10,0,0,0" Height="40" Padding="15,5" Command="{Binding HEXCommand}" Background="#2196F3" Foreground="White"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
